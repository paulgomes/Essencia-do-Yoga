---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Studio de Yoga Sorocaba - Essência Do Yoga',
  description = 'Studio de Yoga Sorocaba: No coração de Sorocaba, nasce um espaço dedicado ao equilíbrio, à consciência e ao bem-estar.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = 'https://essenciadoyoga.com.br/images/yoga-studio.webp';
---

<!DOCTYPE html>
<html dir="ltr" lang="pt-BR" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />
  <title>{title}</title>

  <meta name="description" content={description} />
  <meta name="robots" content="max-image-preview:large" />
  <link rel="canonical" href={canonicalURL} />

  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="essenciadoyoga.com.br -" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="Studio de Yoga Sorocaba" />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:width" content="2048" />
  <meta property="og:image:height" content="2048" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Studio de Yoga Sorocaba" />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Geo -->
  <meta name="geo.region" content="BR-SP" />
  <meta name="geo.placename" content="Sorocaba" />
  <meta name="geo.position" content="-23.5015;-47.4526" />
  <meta name="ICBM" content="-23.5015, -47.4526" />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <meta name="theme-color" content="#154A30" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <!-- Fontes (Cormorant Garamond + Outfit, mesmas do original) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <!-- Schema HealthClub completo (idêntico ao original) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HealthClub",
    "name": "Essência do Yoga",
    "description": "Studio de yoga em Sorocaba com turmas pequenas, horários flexíveis e atendimento personalizado. Aulas de Hatha, Vinyasa e meditação no coração da cidade.",
    "image": "https://essenciadoyoga.com.br/images/logo.png",
    "url": "https://essenciadoyoga.com.br/",
    "telephone": "+55 15 99133-1624",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rua Goiás, 117",
      "addressLocality": "Sorocaba",
      "addressRegion": "SP",
      "postalCode": "18035-620",
      "addressCountry": "BR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -23.5015,
      "longitude": -47.4526
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "07:00",
        "closes": "21:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "07:00",
        "closes": "21:00"
      }
    ],
    "sameAs": ["https://www.instagram.com/essencia_do_yoga/"]
  })} />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Outfit', system-ui, -apple-system, sans-serif;
    color: #18241C;
    background: #FFFFFF;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  img, picture, video { max-width: 100%; height: auto; display: block; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; background: none; border: none; cursor: pointer; color: inherit; }
  ul, ol { list-style: none; }
  :focus-visible { outline: 2px solid #1D603E; outline-offset: 3px; }
</style>
