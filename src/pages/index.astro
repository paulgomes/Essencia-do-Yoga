---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Modalidades from '../components/Modalidades.astro';
import Professora from '../components/Professora.astro';
import CTA from '../components/CTA.astro';
import QueEYoga from '../components/QueEYoga.astro';
import Footer from '../components/Footer.astro';
import FloatingButton from '../components/FloatingButton.astro';
---

<BaseLayout>
  <Hero />
  <main id="main">
    <Stats />
    <Modalidades />
    <Professora />
    <CTA />
    <QueEYoga />
  </main>
  <Footer />
  <FloatingButton />
</BaseLayout>
