---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beneficios from '../components/Beneficios.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import FloatingButton from '../components/FloatingButton.astro';

const title = 'Aulas de Yoga em Sorocaba | Hatha, Vinyasa e Meditação | Essência do Yoga';
const description = 'Aulas de yoga em Sorocaba/SP para iniciantes e praticantes. Hatha, Vinyasa, meditação e pranayama no Centro. Turmas pequenas, horários flexíveis. Agende sua aula experimental.';
const keywords = 'aulas de yoga sorocaba, aulas de yoga em sorocaba, hatha yoga sorocaba, vinyasa sorocaba, yoga iniciantes sorocaba, studio yoga sorocaba';
const ogImage = 'https://essenciadoyoga.com.br/images/og-aulas-yoga.jpg';

const beneficiosAulas = [
  { num: "01", titulo: "Corpo mais forte", desc: "Posturas que fortalecem músculos profundos, melhoram a postura e aumentam a flexibilidade." },
  { num: "02", titulo: "Menos estresse", desc: "Respiração consciente e meditação reduzem cortisol e trazem clareza mental." },
  { num: "03", titulo: "Sono profundo", desc: "A prática regular regula o sistema nervoso e melhora a qualidade do sono." },
  { num: "04", titulo: "Foco mental", desc: "Pranayama e meditação aprimoram concentração e produtividade no dia a dia." },
  { num: "05", titulo: "Energia equilibrada", desc: "Aulas pela manhã ou final do dia recarregam corpo e mente sem esgotar." },
  { num: "06", titulo: "Comunidade acolhedora", desc: "Pratique cercado de pessoas em busca dos mesmos valores — leveza e presença." },
];

const estilos = [
  { num: "01", nome: "Hatha Yoga", desc: "Para quem busca uma prática mais lenta, com foco em alinhamento, respiração e permanência nas posturas. Ideal para iniciantes.", img: "yoga-adultos" },
  { num: "02", nome: "Vinyasa Yoga", desc: "Sequências dinâmicas de posturas sincronizadas com a respiração. Trabalha condicionamento físico e fluidez.", img: "yoga-adultos" },
  { num: "03", nome: "Meditação & Pranayama", desc: "Aulas dedicadas a técnicas de respiração e meditação guiada. Para acalmar a mente e cultivar presença.", img: "yoga-todos" },
];

const faqAulas = [
  { q: "Preciso ter experiência prévia para fazer yoga?", a: "Não. As aulas são adaptadas para iniciantes. Você aprende as posturas básicas no seu ritmo, com instruções claras." },
  { q: "Qual estilo de yoga é melhor para iniciantes?", a: "Hatha Yoga é o ideal para começar — prática mais lenta, com foco em alinhamento e respiração. Depois você pode experimentar Vinyasa." },
  { q: "Quantas vezes por semana devo praticar?", a: "2 a 3 vezes por semana é o ideal para sentir benefícios consistentes. Mas mesmo 1x já faz diferença." },
  { q: "Quanto tempo dura cada aula?", a: "60 minutos para Hatha e Vinyasa, 45 minutos para meditação." },
  { q: "Posso fazer yoga com problema na coluna ou joelho?", a: "Sim, com adaptações. Avise a professora antes da aula sobre qualquer limitação e ela vai adequar as posturas." },
  { q: "Que material preciso levar?", a: "Apenas roupas confortáveis. Tapetes e blocos ficam disponíveis no studio." },
  { q: "Onde fica o studio?", a: "Rua Goiás, 117, Centro, Sorocaba/SP — fácil acesso e estacionamento na região." },
];

// JSON-LD adicional injetado no body (Google lê de qualquer lugar)
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://essenciadoyoga.com.br/aulas-de-yoga-sorocaba#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://essenciadoyoga.com.br/" },
        { "@type": "ListItem", "position": 2, "name": "Aulas de Yoga em Sorocaba", "item": "https://essenciadoyoga.com.br/aulas-de-yoga-sorocaba" }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://essenciadoyoga.com.br/#service-hatha",
      "name": "Hatha Yoga em Sorocaba",
      "serviceType": "Aulas de Hatha Yoga",
      "description": "Prática lenta com foco em alinhamento, respiração e permanência nas posturas. Ideal para iniciantes.",
      "provider": { "@type": "LocalBusiness", "@id": "https://essenciadoyoga.com.br/#studio" },
      "areaServed": { "@type": "City", "name": "Sorocaba" }
    },
    {
      "@type": "Service",
      "@id": "https://essenciadoyoga.com.br/#service-vinyasa",
      "name": "Vinyasa Yoga em Sorocaba",
      "serviceType": "Aulas de Vinyasa Yoga",
      "description": "Sequências dinâmicas sincronizadas com a respiração. Trabalha condicionamento físico e fluidez.",
      "provider": { "@type": "LocalBusiness", "@id": "https://essenciadoyoga.com.br/#studio" },
      "areaServed": { "@type": "City", "name": "Sorocaba" }
    },
    {
      "@type": "Service",
      "@id": "https://essenciadoyoga.com.br/#service-meditacao",
      "name": "Meditação e Pranayama em Sorocaba",
      "serviceType": "Aulas de Meditação e Pranayama",
      "description": "Técnicas de respiração e meditação guiada para acalmar a mente e cultivar presença.",
      "provider": { "@type": "LocalBusiness", "@id": "https://essenciadoyoga.com.br/#studio" },
      "areaServed": { "@type": "City", "name": "Sorocaba" }
    },
    {
      "@type": "FAQPage",
      "@id": "https://essenciadoyoga.com.br/aulas-de-yoga-sorocaba#faq",
      "mainEntity": faqAulas.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    }
  ]
};
---

<BaseLayout title={title} description={description} keywords={keywords} ogImage={ogImage} pageType="generic">
  <!-- Hero -->
  <section id="hero-aulas" class="lp-hero" aria-labelledby="aulasHeroTitle">
    <div class="lp-hero__bg" aria-hidden="true">
      <picture>
        <source media="(max-width: 640px)" srcset="/images/yoga-sunset-poster-640.webp" type="image/webp" />
        <source media="(max-width: 1024px)" srcset="/images/yoga-sunset-poster-1024.webp" type="image/webp" />
        <img src="/images/yoga-sunset-poster-1920.webp" alt="" width="1920" height="1080" fetchpriority="high" decoding="sync" />
      </picture>
    </div>
    <div class="lp-hero__overlay" aria-hidden="true"></div>
    <div class="lp-hero__content">
      <p class="lp-hero__tag">Aulas de Yoga em Sorocaba</p>
      <h1 class="lp-hero__title" id="aulasHeroTitle">
        Aulas de <em>Yoga</em> em Sorocaba para <em>todos os corpos</em> e ritmos.
      </h1>
      <p class="lp-hero__desc">
        Hatha, Vinyasa, meditação e pranayama no coração de Sorocaba. Turmas pequenas, professora certificada e horários flexíveis para você praticar quando der.
      </p>
      <a href="#contato" class="lp-hero__cta">Agendar aula experimental</a>
      <ul class="lp-hero__features" role="list">
        <li><span aria-hidden="true">✓</span> Aulas para iniciantes e avançados</li>
        <li><span aria-hidden="true">✓</span> Hatha, Vinyasa e Meditação</li>
        <li><span aria-hidden="true">✓</span> Turmas de até 10 alunos</li>
      </ul>
    </div>
  </section>

  <main id="main">
    <!-- Stats -->
    <section class="lp-stats">
      <div class="lp-stats__container">
        <p class="lp-stats__eyebrow">Aulas em Números</p>
        <div class="lp-stats__grid">
          <div class="lp-stats__item"><p class="lp-stats__value">500+</p><p class="lp-stats__label">Alunos atendidos</p></div>
          <div class="lp-stats__item"><p class="lp-stats__value">8+</p><p class="lp-stats__label">Anos de experiência</p></div>
          <div class="lp-stats__item"><p class="lp-stats__value">15+</p><p class="lp-stats__label">Horários semanais</p></div>
        </div>
      </div>
    </section>

    <Beneficios
      eyebrow="Benefícios"
      title="Por que praticar <em>yoga em Sorocaba</em> conosco"
      intro="A prática regular transforma corpo, mente e rotina. Veja o que o yoga pode fazer por você."
      items={beneficiosAulas}
    />

    <!-- Modalidades (estilos) -->
    <section class="lp-mod" id="estilos" aria-labelledby="estilosTitle">
      <div class="lp-mod__container">
        <header class="lp-mod__header">
          <p class="lp-mod__eyebrow">Estilos</p>
          <h2 class="lp-mod__title" id="estilosTitle">Estilos de <em>yoga</em> oferecidos em Sorocaba</h2>
        </header>
        <div class="lp-mod__grid">
          {estilos.map((e) => (
            <article class="lp-mod__card">
              <figure class="lp-mod__media">
                <img loading="lazy" decoding="async" src={`/images/${e.img}-600.webp`} srcset={`/images/${e.img}-400.webp 400w, /images/${e.img}-600.webp 600w, /images/${e.img}-900.webp 900w`} sizes="(max-width: 640px) 100vw, 33vw" alt={`Aula de ${e.nome} em Sorocaba`} width="600" height="600" />
                <span class="lp-mod__num" aria-hidden="true">{e.num}</span>
              </figure>
              <div class="lp-mod__body">
                <h3 class="lp-mod__name">{e.nome}</h3>
                <p class="lp-mod__desc">{e.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="lp-cta" aria-label="Agendar aula experimental">
      <div class="lp-cta__bg" aria-hidden="true"></div>
      <div class="lp-cta__overlay" aria-hidden="true"></div>
      <div class="lp-cta__container">
        <div class="lp-cta__inner">
          <p class="lp-cta__eyebrow">Aula Experimental</p>
          <h2 class="lp-cta__title">Comece sua jornada com uma <em>aula experimental</em></h2>
          <p class="lp-cta__text">Conheça o studio, a professora e descubra qual estilo de yoga combina com você. Sem compromisso.</p>
          <a href="#contato" class="lp-cta__btn">
            <span>Agendar pelo WhatsApp</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- O que esperar -->
    <section class="lp-oque" aria-labelledby="oqueTitle">
      <div class="lp-oque__container">
        <header class="lp-oque__header">
          <p class="lp-oque__eyebrow">A Prática</p>
          <h2 class="lp-oque__title" id="oqueTitle">O que esperar das <em>aulas de yoga</em> em Sorocaba?</h2>
        </header>
        <div class="lp-oque__body">
          <p>O yoga vai muito além das posturas físicas. É um sistema milenar de autoconhecimento que integra movimento, respiração e atenção plena.</p>
          <p>Nas aulas do <strong>Essência do Yoga</strong>, cada sessão é estruturada para acolher seu nível atual — seja seu primeiro contato com a prática ou anos de experiência. Trabalhamos com turmas pequenas para que cada aluno receba atenção individual. Para crianças, conheça nossas <a href="/yoga-kids-sorocaba">aulas de Yoga Kids</a>.</p>
          <blockquote class="lp-oque__quote">
            "A primeira aula muda como você respira. As próximas, como você vive."
          </blockquote>
          <div class="lp-oque__tags" role="list">
            <span class="lp-oque__tag" role="listitem">Presença</span>
            <span class="lp-oque__tag" role="listitem">Movimento</span>
            <span class="lp-oque__tag" role="listitem">Respiração</span>
          </div>
        </div>
      </div>
    </section>

    <Faq
      eyebrow="Dúvidas Frequentes"
      title='Perguntas frequentes sobre as <em>aulas de yoga</em> em Sorocaba'
      questions={faqAulas}
    />
  </main>

  <Footer />
  <FloatingButton />

  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .lp-hero {
    position: relative; min-height: 75vh; min-height: 75dvh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; background: #1a2820; color: #fff;
    padding: clamp(3rem, 2.5rem + 2vw, 5rem) clamp(1.5rem, 1rem + 3vw, 4rem);
  }
  .lp-hero__bg { position: absolute; inset: 0; z-index: 1; }
  .lp-hero__bg picture, .lp-hero__bg img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center 30%;
    filter: brightness(.45) saturate(1.05);
  }
  .lp-hero__overlay {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(180deg, rgba(15, 46, 30, 0.55) 0%, rgba(15, 46, 30, 0.85) 100%);
  }
  .lp-hero__content {
    position: relative; z-index: 5; max-width: 760px; width: 100%;
    text-align: center; display: flex; flex-direction: column;
    align-items: center; gap: clamp(0.9rem, 2vh, 1.4rem);
  }
  .lp-hero__tag {
    display: inline-flex; padding: 7px 20px;
    background: rgba(190, 235, 172, 0.15);
    border: 1px solid rgba(190, 235, 172, 0.45);
    border-radius: 999px;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 3px;
    color: #BEEBAC; margin: 0;
  }
  .lp-hero__title {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(2rem, 1.4rem + 3vw, 3.6rem);
    line-height: 1.08; font-weight: 300; letter-spacing: -0.02em;
    color: #fff; margin: 0; text-wrap: balance;
  }
  .lp-hero__title em { font-style: italic; color: #BEEBAC; }
  .lp-hero__desc {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: clamp(0.95rem, 0.9rem + 0.25vw, 1.1rem);
    font-weight: 300; color: rgba(255, 255, 255, 0.92);
    line-height: 1.7; max-width: 640px; margin: 0 auto;
  }
  .lp-hero__cta {
    display: inline-flex; align-items: center; justify-content: center;
    min-height: 48px; padding: 14px 32px; background: #fff; color: #154A30 !important;
    border-radius: 999px;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-weight: 800; font-size: 12px; text-transform: uppercase; letter-spacing: 1.6px;
    text-decoration: none; transition: all .35s ease;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18); margin-top: 0.5rem;
  }
  .lp-hero__cta:hover { background: #BEEBAC; transform: translateY(-3px); }
  .lp-hero__features {
    list-style: none; padding: 0; margin: 1rem 0 0;
    display: flex; flex-direction: column; gap: 0.5rem;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.92rem; color: rgba(255, 255, 255, 0.85);
  }
  .lp-hero__features li { display: flex; align-items: center; gap: 0.6rem; }
  .lp-hero__features li span { color: #BEEBAC; font-weight: 700; }

  /* ===== STATS ===== */
  .lp-stats { background: var(--bg-light-2); color: #1a1a1a; padding: clamp(3rem, 2.5rem + 2vw, 5rem) 0; }
  .lp-stats__container {
    max-width: 1200px; margin: 0 auto;
    padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); text-align: center;
  }
  .lp-stats__eyebrow {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: #a484b6; font-weight: 500;
    margin: 0 0 clamp(1.5rem, 1.25rem + 1vw, 2.5rem);
  }
  .lp-stats__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 0.5rem + 2vw, 3rem);
  }
  .lp-stats__item { contain: layout style; }
  .lp-stats__value {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(2rem, 1.4rem + 3vw, 4rem);
    font-weight: 300; line-height: 1; color: #154A30; margin: 0 0 0.65rem;
    letter-spacing: -0.03em;
  }
  .lp-stats__label {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-style: italic;
    font-size: clamp(0.85rem, 0.8rem + 0.3vw, 1.15rem);
    color: #5a5a5a; margin: 0;
  }

  /* ===== MODALIDADES/ESTILOS ===== */
  .lp-mod { padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0; background: var(--bg-light-1); scroll-margin-top: 80px; }
  .lp-mod__container { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); }
  .lp-mod__header { text-align: center; margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.5rem); max-width: 720px; margin-left: auto; margin-right: auto; }
  .lp-mod__eyebrow {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.22em;
    text-transform: uppercase; color: #CC6BE6; margin: 0 0 1rem;
  }
  .lp-mod__title {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem); font-weight: 300;
    line-height: 1.05; letter-spacing: -0.02em; color: #18241C; margin: 0;
    text-wrap: balance;
  }
  .lp-mod__title em { font-style: italic; color: #1D603E; }
  .lp-mod__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 1rem + 1vw, 2rem); }
  .lp-mod__card {
    background: #EAF7E4; border-radius: 24px; overflow: hidden;
    display: flex; flex-direction: column; contain: layout style;
    transition: transform 500ms ease, box-shadow 500ms ease;
  }
  .lp-mod__card:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(15, 26, 18, 0.12); }
  .lp-mod__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; margin: 0; }
  .lp-mod__media img { width: 100%; height: 100%; object-fit: cover; }
  .lp-mod__num {
    position: absolute; top: 12px; left: 12px; padding: 0.3rem 0.7rem;
    background: rgba(15, 26, 18, 0.4);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-radius: 999px; color: #fff;
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-style: italic; font-size: 0.85rem; letter-spacing: 0.05em;
  }
  .lp-mod__body { padding: clamp(1.25rem, 1rem + 0.5vw, 1.75rem); display: flex; flex-direction: column; gap: 0.6rem; }
  .lp-mod__name {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
    font-weight: 400; color: #18241C; margin: 0; line-height: 1.2;
  }
  .lp-mod__desc {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.9rem; line-height: 1.6; color: #46514A; margin: 0;
  }
  @media (max-width: 860px) { .lp-mod__grid { grid-template-columns: 1fr; gap: 1.25rem; } }

  /* ===== CTA ===== */
  .lp-cta { position: relative; padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0; overflow: hidden; background: #0a1f10; }
  .lp-cta__bg {
    position: absolute; inset: 0; z-index: 0;
    background-image: url('/images/cta-bg.webp'); background-size: cover; background-position: center;
  }
  .lp-cta__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(10, 31, 16, 0.85), rgba(21, 74, 48, 0.80) 50%, rgba(10, 31, 16, 0.88));
  }
  .lp-cta__container {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem);
    display: flex; justify-content: center;
  }
  .lp-cta__inner {
    max-width: 720px; text-align: center; color: #fff;
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  .lp-cta__eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.22em;
    text-transform: uppercase; color: #E0A8EE; margin: 0;
  }
  .lp-cta__eyebrow::before { content: ""; width: 28px; height: 1px; background: #E0A8EE; }
  .lp-cta__title {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(1.85rem, 1.4rem + 2vw, 3rem);
    font-weight: 300; line-height: 1.1; color: #fff; margin: 0; text-wrap: balance;
  }
  .lp-cta__title em { font-style: italic; color: #BEEBAC; }
  .lp-cta__text {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 1rem; line-height: 1.7; color: rgba(255, 255, 255, 0.92);
    max-width: 560px; margin: 0;
  }
  .lp-cta__btn {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 14px 32px; background: #fff; color: #154A30 !important;
    border-radius: 999px;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-weight: 700; font-size: 0.85rem; letter-spacing: 0.06em;
    text-transform: uppercase; text-decoration: none;
    transition: all 400ms ease; box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2); margin-top: 0.5rem;
  }
  .lp-cta__btn:hover { background: #BEEBAC; transform: translateY(-3px); }
  .lp-cta__btn svg { width: 15px; height: 15px; stroke: #154A30; }

  /* ===== O QUE ESPERAR ===== */
  .lp-oque { padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0; background: var(--bg-light-2); scroll-margin-top: 80px; }
  .lp-oque__container { max-width: 760px; margin: 0 auto; padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); }
  .lp-oque__header { text-align: center; margin-bottom: 1.5rem; }
  .lp-oque__eyebrow {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.22em;
    text-transform: uppercase; color: #CC6BE6; margin: 0 0 1rem;
