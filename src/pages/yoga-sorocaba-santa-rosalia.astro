---
import BaseLayout from '../layouts/BaseLayout.astro';
import Beneficios from '../components/Beneficios.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import FloatingButton from '../components/FloatingButton.astro';

const title = 'Yoga em Santa Rosália, Sorocaba | Essência do Yoga';
const description = 'Procurando aulas de yoga próximo a Santa Rosália em Sorocaba? O studio Essência do Yoga fica no Centro, fácil acesso de Santa Rosália. Hatha, Vinyasa e meditação.';
const keywords = 'yoga santa rosalia sorocaba, yoga sorocaba santa rosalia, aulas yoga santa rosalia, studio yoga proximo santa rosalia';
const ogImage = 'https://essenciadoyoga.com.br/images/og-cover.jpg'; // TODO: og-santa-rosalia.jpg

const beneficiosBairro = [
  { num: "01", titulo: "Acesso fácil", desc: "A apenas 10 minutos de carro de Santa Rosália, pela Av. Itavuvu ou Av. Dom Aguirre." },
  { num: "02", titulo: "Estacionamento", desc: "Vagas disponíveis na região e ruas próximas ao studio." },
  { num: "03", titulo: "Horários flexíveis", desc: "Aulas pela manhã, almoço e final do dia — escolha o que cabe no seu trajeto." },
  { num: "04", titulo: "Ambiente acolhedor", desc: "Studio pequeno e silencioso, longe do barulho de academias grandes." },
  { num: "05", titulo: "Professora dedicada", desc: "Atendimento personalizado em turmas de no máximo 10 alunos." },
  { num: "06", titulo: "Comunidade local", desc: "Encontre pessoas de Sorocaba que valorizam saúde e bem-estar como você." },
];

const modalidades = [
  { num: "01", nome: "Yoga Adultos", desc: "Hatha e Vinyasa para fortalecer corpo, aliviar estresse e cultivar presença.", img: "yoga-adultos" },
  { num: "02", nome: "Yoga Mamãe & Bebê", desc: "Práticas leves para mães no pós-parto fortalecerem o vínculo com o bebê.", img: "yoga-mamae-bebe" },
  { num: "03", nome: "Yoga Kids", desc: "Aulas lúdicas para crianças de 4 a 13 anos com foco em concentração e equilíbrio emocional.", img: "yoga-kids" },
];

const faqBairro = [
  { q: "Qual a distância entre Santa Rosália e o studio?", a: "Aproximadamente 4 km, cerca de 10 minutos de carro pela Av. Itavuvu ou Av. Dom Aguirre." },
  { q: "Tem estacionamento perto?", a: "Sim, vagas livres em ruas próximas e estacionamentos pagos no Centro." },
  { q: "Quais horários funcionam melhor pra quem vem de Santa Rosália?", a: "Manhã cedo (7h), almoço (12h) ou após o trabalho (18h–20h) — fora dos horários de pico de trânsito." },
  { q: "É possível ir de transporte público?", a: "Sim, várias linhas de ônibus conectam Santa Rosália ao Centro de Sorocaba." },
  { q: "Vocês têm aulas para iniciantes?", a: "Sim, todas as aulas acomodam iniciantes. A professora adapta as posturas individualmente." },
  { q: "E para crianças e gestantes?", a: "Temos Yoga Kids (4-13 anos) e Yoga Mamãe & Bebê para pós-parto. Veja todas as modalidades no site." },
  { q: "Onde fica o studio exatamente?", a: "Rua Goiás, 117, Centro, Sorocaba/SP. Veja no mapa: https://maps.app.goo.gl/bCnMqvaWc7wVodJf6" },
];

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://essenciadoyoga.com.br/yoga-sorocaba-santa-rosalia#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://essenciadoyoga.com.br/" },
        { "@type": "ListItem", "position": 2, "name": "Yoga próximo a Santa Rosália", "item": "https://essenciadoyoga.com.br/yoga-sorocaba-santa-rosalia" }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://essenciadoyoga.com.br/#service-bairro-santa-rosalia",
      "name": "Aulas de yoga próximo a Santa Rosália, Sorocaba",
      "serviceType": "Aulas de Yoga",
      "description": "Studio de yoga no Centro de Sorocaba, a 10 minutos de Santa Rosália. Hatha, Vinyasa, meditação, yoga kids e yoga mamãe & bebê.",
      "provider": { "@type": "LocalBusiness", "@id": "https://essenciadoyoga.com.br/#studio" },
      "areaServed": [
        {
          "@type": "Place",
          "name": "Santa Rosália",
          "containedInPlace": {
            "@type": "City",
            "name": "Sorocaba",
            "sameAs": "https://www.wikidata.org/wiki/Q201794"
          }
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://essenciadoyoga.com.br/yoga-sorocaba-santa-rosalia#faq",
      "mainEntity": faqBairro.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    }
  ]
};
---

<BaseLayout title={title} description={description} keywords={keywords} ogImage={ogImage} pageType="generic">
  <section id="hero" class="lp-hero" aria-labelledby="heroTitle">
    <div class="lp-hero__bg" aria-hidden="true">
      <picture>
        <source media="(max-width: 640px)" srcset="/images/yoga-sunset-poster-640.webp" type="image/webp" />
        <source media="(max-width: 1024px)" srcset="/images/yoga-sunset-poster-1024.webp" type="image/webp" />
        <img src="/images/yoga-sunset-poster-1920.webp" alt="" width="1920" height="1080" fetchpriority="high" decoding="sync" />
      </picture>
    </div>
    <div class="lp-hero__overlay" aria-hidden="true"></div>
    <div class="lp-hero__content">
      <p class="lp-hero__tag">Yoga próximo a Santa Rosália — Sorocaba</p>
      <h1 class="lp-hero__title" id="heroTitle">
        Yoga em <em>Sorocaba</em> para quem mora em <em>Santa Rosália</em>.
      </h1>
      <p class="lp-hero__desc">
        O Essência do Yoga fica no Centro de Sorocaba, a poucos minutos de Santa Rosália. Ambiente acolhedor, professora certificada e turmas pequenas.
      </p>
      <a href="#contato" class="lp-hero__cta">Agendar aula experimental</a>
      <ul class="lp-hero__features" role="list">
        <li><span aria-hidden="true">✓</span> 10 minutos de Santa Rosália</li>
        <li><span aria-hidden="true">✓</span> Estacionamento próximo</li>
        <li><span aria-hidden="true">✓</span> Horários da manhã, tarde e noite</li>
      </ul>
    </div>
  </section>

  <main id="main">
    <section class="lp-stats">
      <div class="lp-stats__container">
        <p class="lp-stats__eyebrow">O Studio em Números</p>
        <div class="lp-stats__grid">
          <div class="lp-stats__item"><p class="lp-stats__value">500+</p><p class="lp-stats__label">Alunos atendidos</p></div>
          <div class="lp-stats__item"><p class="lp-stats__value">10 min</p><p class="lp-stats__label">de Santa Rosália</p></div>
          <div class="lp-stats__item"><p class="lp-stats__value">3</p><p class="lp-stats__label">Modalidades</p></div>
        </div>
      </div>
    </section>

    <Beneficios
      eyebrow="Vantagens"
      title="Por que vale praticar no <em>Centro vindo de Santa Rosália</em>"
      intro="O trajeto curto, os horários flexíveis e o ambiente acolhedor fazem do Essência uma extensão natural do seu bairro."
      items={beneficiosBairro}
    />

    <section class="lp-mod" id="modalidades" aria-labelledby="modTitle">
      <div class="lp-mod__container">
        <header class="lp-mod__header">
          <p class="lp-mod__eyebrow">Modalidades</p>
          <h2 class="lp-mod__title" id="modTitle">Aulas <em>disponíveis</em> no studio</h2>
        </header>
        <div class="lp-mod__grid">
          {modalidades.map((m) => (
            <article class="lp-mod__card">
              <figure class="lp-mod__media">
                <img loading="lazy" decoding="async" src={`/images/${m.img}-600.webp`} srcset={`/images/${m.img}-400.webp 400w, /images/${m.img}-600.webp 600w, /images/${m.img}-900.webp 900w`} sizes="(max-width: 640px) 100vw, 33vw" alt={`Aula de ${m.nome} no Essência do Yoga`} width="600" height="600" />
                <span class="lp-mod__num" aria-hidden="true">{m.num}</span>
              </figure>
              <div class="lp-mod__body">
                <h3 class="lp-mod__name">{m.nome}</h3>
                <p class="lp-mod__desc">{m.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="lp-cta" aria-label="Agendar aula experimental">
      <div class="lp-cta__bg" aria-hidden="true"></div>
      <div class="lp-cta__overlay" aria-hidden="true"></div>
      <div class="lp-cta__container">
        <div class="lp-cta__inner">
          <p class="lp-cta__eyebrow">Aula Experimental</p>
          <h2 class="lp-cta__title">Que tal experimentar uma aula <em>vindo de Santa Rosália</em>?</h2>
          <p class="lp-cta__text">Você dirige 10 minutos e descobre um espaço de respiro no meio do dia. Aula experimental sem compromisso.</p>
          <a href="#contato" class="lp-cta__btn">
            <span>Agendar pelo WhatsApp</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="lp-oque" aria-labelledby="oqueTitle">
      <div class="lp-oque__container">
        <header class="lp-oque__header">
          <p class="lp-oque__eyebrow">Para você de Santa Rosália</p>
          <h2 class="lp-oque__title" id="oqueTitle">Yoga <em>acessível</em> para moradores de Santa Rosália</h2>
        </header>
        <div class="lp-oque__body">
          <p>Sabemos que Santa Rosália é um bairro residencial movimentado, com famílias que correm o dia inteiro entre trabalho, escola e compromissos. Encontrar tempo para si mesmo virou um luxo.</p>
          <p>O <strong>Essência do Yoga</strong> fica no Centro de Sorocaba, a poucos minutos do bairro pela Av. Itavuvu. Oferecemos horários estratégicos — antes do trabalho, no almoço ou ao final da tarde — para você caber a prática na sua rotina sem complicação. <a href="/aulas-de-yoga-sorocaba">Conheça todas as modalidades oferecidas</a>.</p>
          <blockquote class="lp-oque__quote">
            "O melhor presente que você pode se dar é tempo para respirar."
          </blockquote>
          <div class="lp-oque__tags" role="list">
            <span class="lp-oque__tag" role="listitem">Acesso fácil</span>
            <span class="lp-oque__tag" role="listitem">Horários flexíveis</span>
            <span class="lp-oque__tag" role="listitem">Bem-estar</span>
          </div>
        </div>
      </div>
    </section>

    <Faq
      eyebrow="Dúvidas Frequentes"
      title='Perguntas frequentes — Yoga próximo a <em>Santa Rosália</em>'
      questions={faqBairro}
    />
  </main>

  <Footer />
  <FloatingButton />

  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
</BaseLayout>

<style>
  /* ===== Reaproveita estilos de landing — mesmas classes lp-* ===== */
  .lp-hero { position: relative; min-height: 75vh; min-height: 75dvh; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #1a2820; color: #fff; padding: clamp(3rem, 2.5rem + 2vw, 5rem) clamp(1.5rem, 1rem + 3vw, 4rem); }
  .lp-hero__bg { position: absolute; inset: 0; z-index: 1; }
  .lp-hero__bg picture, .lp-hero__bg img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; filter: brightness(.45) saturate(1.05); }
  .lp-hero__overlay { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, rgba(15, 46, 30, 0.55) 0%, rgba(15, 46, 30, 0.85) 100%); }
  .lp-hero__content { position: relative; z-index: 5; max-width: 760px; width: 100%; text-align: center; display: flex; flex-direction: column; align-items: center; gap: clamp(0.9rem, 2vh, 1.4rem); }
  .lp-hero__tag { display: inline-flex; padding: 7px 20px; background: rgba(190, 235, 172, 0.15); border: 1px solid rgba(190, 235, 172, 0.45); border-radius: 999px; font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 3px; color: #BEEBAC; margin: 0; }
  .lp-hero__title { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-size: clamp(2rem, 1.4rem + 3vw, 3.6rem); line-height: 1.08; font-weight: 300; letter-spacing: -0.02em; color: #fff; margin: 0; text-wrap: balance; }
  .lp-hero__title em { font-style: italic; color: #BEEBAC; }
  .lp-hero__desc { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: clamp(0.95rem, 0.9rem + 0.25vw, 1.1rem); font-weight: 300; color: rgba(255, 255, 255, 0.92); line-height: 1.7; max-width: 640px; margin: 0 auto; }
  .lp-hero__cta { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 14px 32px; background: #fff; color: #154A30 !important; border-radius: 999px; font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-weight: 800; font-size: 12px; text-transform: uppercase; letter-spacing: 1.6px; text-decoration: none; transition: all .35s ease; box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18); margin-top: 0.5rem; }
  .lp-hero__cta:hover { background: #BEEBAC; transform: translateY(-3px); }
  .lp-hero__features { list-style: none; padding: 0; margin: 1rem 0 0; display: flex; flex-direction: column; gap: 0.5rem; font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.92rem; color: rgba(255, 255, 255, 0.85); }
  .lp-hero__features li { display: flex; align-items: center; gap: 0.6rem; }
  .lp-hero__features li span { color: #BEEBAC; font-weight: 700; }

  .lp-stats { background: var(--bg-light-2); color: #1a1a1a; padding: clamp(3rem, 2.5rem + 2vw, 5rem) 0; }
  .lp-stats__container { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); text-align: center; }
  .lp-stats__eyebrow { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase; color: #a484b6; font-weight: 500; margin: 0 0 clamp(1.5rem, 1.25rem + 1vw, 2.5rem); }
  .lp-stats__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 0.5rem + 2vw, 3rem); }
  .lp-stats__item { contain: layout style; }
  .lp-stats__value { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-size: clamp(2rem, 1.4rem + 3vw, 4rem); font-weight: 300; line-height: 1; color: #154A30; margin: 0 0 0.65rem; letter-spacing: -0.03em; }
  .lp-stats__label { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-style: italic; font-size: clamp(0.85rem, 0.8rem + 0.3vw, 1.15rem); color: #5a5a5a; margin: 0; }

  .lp-mod { padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0; background: var(--bg-light-1); scroll-margin-top: 80px; }
  .lp-mod__container { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); }
  .lp-mod__header { text-align: center; margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.5rem); max-width: 720px; margin-left: auto; margin-right: auto; }
  .lp-mod__eyebrow { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: #CC6BE6; margin: 0 0 1rem; }
  .lp-mod__title { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem); font-weight: 300; line-height: 1.05; letter-spacing: -0.02em; color: #18241C; margin: 0; text-wrap: balance; }
  .lp-mod__title em { font-style: italic; color: #1D603E; }
  .lp-mod__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 1rem + 1vw, 2rem); }
  .lp-mod__card { background: #EAF7E4; border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; contain: layout style; transition: transform 500ms ease, box-shadow 500ms ease; }
  .lp-mod__card:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(15, 26, 18, 0.12); }
  .lp-mod__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; margin: 0; }
  .lp-mod__media img { width: 100%; height: 100%; object-fit: cover; }
  .lp-mod__num { position: absolute; top: 12px; left: 12px; padding: 0.3rem 0.7rem; background: rgba(15, 26, 18, 0.4); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-radius: 999px; color: #fff; font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-style: italic; font-size: 0.85rem; letter-spacing: 0.05em; }
  .lp-mod__body { padding: clamp(1.25rem, 1rem + 0.5vw, 1.75rem); display: flex; flex-direction: column; gap: 0.6rem; }
  .lp-mod__name { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem); font-weight: 400; color: #18241C; margin: 0; line-height: 1.2; }
  .lp-mod__desc { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.9rem; line-height: 1.6; color: #46514A; margin: 0; }
  @media (max-width: 860px) { .lp-mod__grid { grid-template-columns: 1fr; gap: 1.25rem; } }

  .lp-cta { position: relative; padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0; overflow: hidden; background: #0a1f10; }
  .lp-cta__bg { position: absolute; inset: 0; z-index: 0; background-image: url('/images/cta-bg.webp'); background-size: cover; background-position: center; }
  .lp-cta__overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(10, 31, 16, 0.85), rgba(21, 74, 48, 0.80) 50%, rgba(10, 31, 16, 0.88)); }
  .lp-cta__container { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); display: flex; justify-content: center; }
  .lp-cta__inner { max-width: 720px; text-align: center; color: #fff; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .lp-cta__eyebrow { display: inline-flex; align-items: center; gap: 0.75rem; font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: #E0A8EE; margin: 0; }
  .lp-cta__eyebrow::before { content: ""; width: 28px; height: 1px; background: #E0A8EE; }
  .lp-cta__title { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-size: clamp(1.85rem, 1.4rem + 2vw, 3rem); font-weight: 300; line-height: 1.1; color: #fff; margin: 0; text-wrap: balance; }
  .lp-cta__title em { font-style: italic; color: #BEEBAC; }
  .lp-cta__text { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 1rem; line-height: 1.7; color: rgba(255, 255, 255, 0.92); max-width: 560px; margin: 0; }
  .lp-cta__btn { display: inline-flex; align-items: center; gap: 0.6rem; padding: 14px 32px; background: #fff; color: #154A30 !important; border-radius: 999px; font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-weight: 700; font-size: 0.85rem; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; transition: all 400ms ease; box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2); margin-top: 0.5rem; }
  .lp-cta__btn:hover { background: #BEEBAC; transform: translateY(-3px); }
  .lp-cta__btn svg { width: 15px; height: 15px; stroke: #154A30; }

  .lp-oque { padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0; background: var(--bg-light-2); scroll-margin-top: 80px; }
  .lp-oque__container { max-width: 760px; margin: 0 auto; padding: 0 clamp(1.5rem, 1rem + 3vw, 4rem); }
  .lp-oque__header { text-align: center; margin-bottom: 1.5rem; }
  .lp-oque__eyebrow { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: #CC6BE6; margin: 0 0 1rem; }
  .lp-oque__title { font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem); font-weight: 300; line-height: 1.05; color: #18241C; margin: 0; }
  .lp-oque__title em { font-style: italic; color: #1D603E; }
  .lp-oque__body { font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 1rem; line-height: 1.8; color: #46514A; text-align: center; }
  .lp-oque__body p { margin: 0 0 1.15rem; }
  .lp-oque__body strong { color: #154A30; }
  .lp-oque__body a { color: #1D603E; text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  .lp-oque__quote { margin: 2rem 0 1.5rem; padding: 1.25rem 1.5rem; background: #D6F2CB; border-left: 3px solid #1D603E; border-radius: 16px; font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif; font-style: italic; font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem); color: #154A30; line-height: 1.6; }
  .lp-oque__tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-top: 1rem; }
  .lp-oque__tag { padding: 0.6rem 1.1rem; background: #fff; border: 1px solid rgba(24, 36, 28, 0.1); border-radius: 999px; font-family: 'Outfit', 'Outfit Fallback', sans-serif; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #1D603E; }
</style>
