          </a>
        </div>
      </div>

      <!-- Navegação -->
      <nav class="ey-footer__col" aria-label="Links do rodapé">
        <p class="ey-footer__col-title">Navegação</p>
        <div class="ey-footer__list">
          <a href="#studio">O Studio</a>
          <a href="#modalidades">Modalidades</a>
          <a href="#professora">A Professora</a>
          <a href="#o-que-e-yoga">O que é Yoga</a>
        </div>
      </nav>

      <!-- Contato -->
      <div class="ey-footer__col" itemscope itemtype="https://schema.org/LocalBusiness">
        <meta itemprop="name" content="Essência do Yoga" />
        <p class="ey-footer__col-title">Contato</p>
        <div class="ey-footer__list">
          <a href="tel:+5515991331624" class="ey-footer__contact" itemprop="contactPoint" itemscope itemtype="https://schema.org/ContactPoint">
