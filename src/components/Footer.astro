            <span itemprop="telephone">(15) 99133-1624</span>
            <meta itemprop="contactType" content="customer service" />
            <meta itemprop="availableLanguage" content="pt-BR" />
          </a>
          <a href="https://maps.app.goo.gl/bCnMqvaWc7wVodJf6" target="_blank" rel="noopener" class="ey-footer__contact">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
              Rua Goiás, 117 — Centro, Sorocaba/SP
              <meta itemprop="streetAddress" content="Rua Goiás, 117" />
              <meta itemprop="addressLocality" content="Sorocaba" />
              <meta itemprop="addressRegion" content="SP" />
              <meta itemprop="postalCode" content="18035-620" />
              <meta itemprop="addressCountry" content="BR" />
            </span>
          </a>
          <span class="ey-footer__contact">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <time itemprop="openingHours" datetime="Mo-Sa 07:00-21:00">Seg–Sáb · 07h–21h</time>
          </span>
        </div>
      </div>

      <!-- CTA -->
      <div class="ey-footer__col">
        <p class="ey-footer__col-title">Aula Experimental</p>
        <div class="ey-footer__cta-box">
          <p>Confira os horários e agende agora sua aula experimental</p>
          <a href="#contato" target="_blank" rel="noopener" class="ey-footer__cta-btn">
            <span>Agendar pelo WhatsApp</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

    </div>

    <div class="ey-footer__bottom">
      <p>© 2026 Essência do Yoga · Sorocaba, SP. Todos os direitos reservados.</p>
      <p class="ey-footer__legal">
        <a href="/politica-de-privacidade">Política de Privacidade</a>
      </p>
      <p>Feito com 💜 por <a href="https://agenciawys.com.br/" target="_blank" rel="noopener">Agência WYS</a></p>
    </div>

  </div>
</footer>

<style>
  .ey-footer {
    --green: #1D603E;
    --green-deep: #154A30;
    --green-dark: #0D3520;
    --lime: #BEEBAC;
    --lilac: #CC6BE6;
    --lilac-light: #E0A8EE;
    --white: #FFFFFF;

    --font-serif: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    --font-sans: 'Outfit', 'Outfit Fallback', system-ui, sans-serif;

    --fs-xs: clamp(0.68rem, 0.66rem + 0.12vw, 0.76rem);
    --fs-sm: clamp(0.82rem, 0.8rem + 0.14vw, 0.92rem);
    --fs-base: clamp(0.9rem, 0.88rem + 0.14vw, 1rem);

    --gutter: clamp(1.5rem, 1rem + 3vw, 4rem);
    --r-md: 12px;
    --r-pill: 999px;
    --ease: cubic-bezier(0.22, 1, 0.36, 1);

    width: 100%;
    background: var(--green-deep) !important;
    color: var(--white) !important;
    padding: clamp(3.5rem, 3rem + 3vw, 5.5rem) 0 1.75rem;
    position: relative;
    overflow: hidden;
  }

  .ey-footer *,
  .ey-footer *::before,
  .ey-footer *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .ey-footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--lilac), transparent);
    opacity: 0.35;
  }

  .ey-footer__container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .ey-footer__top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: clamp(2rem, 1.5rem + 2vw, 3.5rem);
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
  }

  .ey-footer__brand { max-width: 340px; }

  .ey-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.25rem;
    text-decoration: none !important;
  }
  .ey-footer__logo img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    opacity: 0.92;
  }
  .ey-footer__logo-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--white) !important;
  }

  .ey-footer__tagline {
    color: rgba(255, 255, 255, 0.68) !important;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .ey-footer__social {
    display: flex;
    gap: 0.6rem;
  }
  .ey-footer__social a {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    color: var(--white) !important;
    text-decoration: none !important;
    transition: all 350ms var(--ease);
  }
  .ey-footer__social a:hover {
    background: var(--lilac) !important;
    border-color: var(--lilac) !important;
    color: var(--white) !important;
    transform: translateY(-2px);
  }
  .ey-footer__social svg {
    width: 17px;
    height: 17px;
  }

  .ey-footer__col-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lilac-light) !important;
    margin-bottom: 1.25rem;
  }

  .ey-footer__list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    list-style: none;
  }

  .ey-footer__list a,
  .ey-footer__list span {
    color: rgba(255, 255, 255, 0.75) !important;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    text-decoration: none !important;
    line-height: 1.5;
    transition: color 200ms var(--ease);
  }
  .ey-footer__list a:hover {
    color: var(--lime) !important;
  }

  .ey-footer__contact {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }
  .ey-footer__contact svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--lime) !important;
    stroke: var(--lime) !important;
  }

  .ey-footer__cta-box {
    padding: 1.15rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--r-md);
    margin-top: 0.75rem;
  }
  .ey-footer__cta-box p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--fs-sm);
    color: var(--white) !important;
    margin-bottom: 0.85rem;
    line-height: 1.5;
  }

  .ey-footer__cta-btn,
  .ey-footer__cta-btn:visited,
  .ey-footer__cta-btn:link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.7rem 1rem;
    border-radius: var(--r-pill);
    background: var(--white) !important;
    color: var(--green-deep) !important;
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none !important;
    transition: all 350ms var(--ease);
  }
  .ey-footer__cta-btn:hover {
    background: var(--lime) !important;
    color: var(--green-deep) !important;
    transform: translateY(-2px);
  }
  .ey-footer__cta-btn svg {
    width: 13px;
    height: 13px;
    stroke: var(--green-deep) !important;
    transition: transform 300ms var(--ease);
  }
  .ey-footer__cta-btn:hover svg {
    transform: translateX(3px);
  }

  .ey-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.45) !important;
  }
  .ey-footer__bottom a {
    color: var(--lilac-light) !important;
    text-decoration: none !important;
    transition: color 200ms var(--ease);
  }
  .ey-footer__bottom a:hover {
    color: var(--white) !important;
  }
  .ey-footer__legal {
    text-align: center;
    flex: 1;
  }

  @media (max-width: 860px) {
    .ey-footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 560px) {
    .ey-footer { padding: 2.5rem 0 1.25rem; }
    .ey-footer__top {
      grid-template-columns: 1fr;
      gap: 0;
      padding-bottom: 1.5rem;
    }
    .ey-footer__brand {
      max-width: 100%;
      text-align: center;
      padding-bottom: 1.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      margin-bottom: 0;
    }
    .ey-footer__logo { justify-content: center; }
    .ey-footer__tagline {
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }
    .ey-footer__social { justify-content: center; }
    .ey-footer__col {
      padding: 1.5rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      text-align: center;
    }
    .ey-footer__col:last-child { border-bottom: none; }
    .ey-footer__col-title { margin-bottom: 0.85rem; }
    .ey-footer__list { align-items: center; }
    .ey-footer__contact { justify-content: center; }
    .ey-footer__cta-box {
      max-width: 300px;
      margin-left: auto;
      margin-right: auto;
    }
    .ey-footer__bottom {
      flex-direction: column;
      text-align: center;
      gap: 0.5rem;
      padding-top: 1.25rem;
    }
  }
</style>
