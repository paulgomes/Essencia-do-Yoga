---
export interface Props {
  eyebrow?: string;
  title?: string;
  questions: Array<{ q: string; a: string }>;
}

const {
  eyebrow = "FAQ",
  title = "Perguntas frequentes",
  questions = [],
} = Astro.props;
---

<section class="ey-faq" id="faq" aria-labelledby="faqTitle">
  <div class="ey-faq__container">
    <header class="ey-faq__header">
      <p class="ey-faq__eyebrow">{eyebrow}</p>
      <h2 class="ey-faq__title" id="faqTitle" set:html={title} />
    </header>

    <div class="ey-faq__list">
      {questions.map((item) => (
        <details class="ey-faq__item">
          <summary class="ey-faq__question">
            <span>{item.q}</span>
            <span class="ey-faq__icon" aria-hidden="true">+</span>
          </summary>
          <p class="ey-faq__answer">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .ey-faq {
    padding-block: clamp(48px, 8vh, 96px);
    background: #faf7f2;
    scroll-margin-top: 80px;
  }

  .ey-faq__container {
    max-width: 860px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 48px);
  }

  .ey-faq__header {
    text-align: center;
    margin: 0 auto clamp(32px, 5vh, 48px);
  }

  .ey-faq__eyebrow {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #CC6BE6;
    margin: 0 0 16px;
    text-align: center;
  }

  .ey-faq__title {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.2;
    margin: 0;
    text-align: center;
    color: #18241C;
  }
  :global(.ey-faq__title em) {
    font-style: italic;
    font-weight: 500;
    color: #154A30;
  }

  .ey-faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ey-faq__item {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    overflow: hidden;
    transition: border-radius 200ms ease, background 200ms ease, border-color 200ms ease;
  }

  .ey-faq__item[open] {
    border-radius: 16px;
    border-color: rgba(21, 74, 48, 0.18);
    background: #fff;
  }

  .ey-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 24px;
    cursor: pointer;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #18241C;
    list-style: none;
    user-select: none;
  }
  .ey-faq__question::-webkit-details-marker { display: none; }

  .ey-faq__icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(21, 74, 48, 0.08);
    color: #154A30;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 400;
    transition: transform 200ms ease, background 200ms ease, color 200ms ease;
  }

  .ey-faq__item[open] .ey-faq__icon {
    transform: rotate(45deg);
    background: #154A30;
    color: #fff;
  }

  .ey-faq__answer {
    padding: 0 24px 20px;
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #46514A;
    margin: 0;
  }

  @media (max-width: 600px) {
    .ey-faq__question { padding: 14px 20px; font-size: 0.875rem; }
    .ey-faq__answer { padding: 0 20px 16px; }
  }
</style>
