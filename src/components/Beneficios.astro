---
const beneficios = [
  { num: "01", titulo: "Concentração", desc: "Práticas de respiração e foco que ajudam no rendimento escolar e na atenção." },
  { num: "02", titulo: "Autoestima", desc: "Posturas que fortalecem o corpo trazem confiança e consciência corporal." },
  { num: "03", titulo: "Controle emocional", desc: "Ferramentas simples para identificar e regular sentimentos como raiva e ansiedade." },
  { num: "04", titulo: "Sono melhor", desc: "Relaxamento guiado que prepara a criança para um descanso profundo." },
  { num: "05", titulo: "Coordenação motora", desc: "Movimentos e equilíbrio que desenvolvem habilidades físicas essenciais." },
  { num: "06", titulo: "Convivência", desc: "Aulas em grupo que ensinam respeito, empatia e cooperação." },
];
---

<section class="ey-ben" id="beneficios" aria-labelledby="beneficiosTitle">
  <div class="ey-ben__container">
    <header class="ey-ben__header">
      <p class="ey-ben__eyebrow">Benefícios</p>
      <h2 class="ey-ben__title" id="beneficiosTitle">
        Benefícios do <em>Yoga para crianças</em> em Sorocaba
      </h2>
      <p class="ey-ben__intro">
        A prática regular oferece ganhos que vão muito além do tatame — habilidades que acompanham seu filho por toda a vida.
      </p>
    </header>

    <div class="ey-ben__grid">
      {beneficios.map((b) => (
        <article class="ey-ben__card">
          <span class="ey-ben__num" aria-hidden="true">{b.num}</span>
          <h3 class="ey-ben__card-title">{b.titulo}</h3>
          <p class="ey-ben__card-desc">{b.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ey-ben {
    --green: #1D603E;
    --green-deep: #154A30;
    --lime: #BEEBAC;
    --lime-pale: #EAF7E4;
    --lilac: #CC6BE6;
    --ink: #18241C;
    --ink-soft: #46514A;
    --line: rgba(24, 36, 28, 0.10);

    --font-serif: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    --font-sans: 'Outfit', 'Outfit Fallback', system-ui, sans-serif;
    --gutter: clamp(1.5rem, 1rem + 3vw, 4rem);

    padding: clamp(3.5rem, 3rem + 3vw, 6rem) 0;
    background:
      radial-gradient(ellipse 50% 40% at 20% 10%, rgba(190, 235, 172, 0.15), transparent 60%),
      #fff;
    scroll-margin-top: 80px;
  }
  .ey-ben * { box-sizing: border-box; margin: 0; padding: 0; }

  .ey-ben__container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .ey-ben__header {
    text-align: center;
    margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3rem);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .ey-ben__eyebrow {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lilac);
    margin: 0 0 1rem !important;
  }

  .ey-ben__title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(2rem, 1.4rem + 2.4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 1.25rem !important;
    text-wrap: balance;
  }
  .ey-ben__title em {
    font-style: italic;
    color: var(--green);
  }

  .ey-ben__intro {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .ey-ben__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 1rem + 1vw, 2rem);
  }

  .ey-ben__card {
    position: relative;
    padding: clamp(1.5rem, 1.25rem + 0.5vw, 2rem);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 20px;
    transition: transform 350ms ease, box-shadow 350ms ease, border-color 350ms ease;
    contain: layout style;
  }
  .ey-ben__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(15, 26, 18, 0.08);
    border-color: var(--lime);
  }

  .ey-ben__num {
    display: inline-block;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--lilac);
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .ey-ben__card-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.2rem, 1.1rem + 0.4vw, 1.5rem);
    color: var(--ink);
    margin: 0 0 0.6rem !important;
    line-height: 1.2;
  }

  .ey-ben__card-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0 !important;
  }

  @media (max-width: 860px) {
    .ey-ben__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .ey-ben__grid { grid-template-columns: 1fr; }
  }
</style>
