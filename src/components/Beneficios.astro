---
const beneficios = [
  { num: "01", titulo: "Concentração", desc: "Práticas de respiração e foco que ajudam no rendimento escolar e na atenção." },
  { num: "02", titulo: "Autoestima", desc: "Posturas que fortalecem o corpo trazem confiança e consciência corporal." },
  { num: "03", titulo: "Controle emocional", desc: "Ferramentas simples para identificar e regular sentimentos como raiva e ansiedade." },
  { num: "04", titulo: "Sono melhor", desc: "Relaxamento guiado que prepara a criança para um descanso profundo." },
  { num: "05", titulo: "Coordenação motora", desc: "Movimentos e equilíbrio que desenvolvem habilidades físicas essenciais." },
  { num: "06", titulo: "Convivência", desc: "Aulas em grupo que ensinam respeito, empatia e cooperação." },
];
---

<section class="ey-beneficios" id="beneficios" aria-labelledby="beneficiosTitle">
  <div class="ey-beneficios__container">
    <header class="ey-beneficios__header">
      <p class="ey-beneficios__eyebrow">Benefícios</p>
      <h2 class="ey-beneficios__title" id="beneficiosTitle">
        Benefícios do <em>Yoga para crianças</em> em Sorocaba
      </h2>
      <p class="ey-beneficios__intro">
        A prática regular oferece ganhos que vão muito além do tatame — habilidades que acompanham seu filho por toda a vida.
      </p>
    </header>

    <div class="ey-beneficios__grid">
      {beneficios.map((b) => (
        <article class="ey-beneficios__card">
          <p class="ey-beneficios__num">{b.num}</p>
          <h3 class="ey-beneficios__card-title">{b.titulo}</h3>
          <p class="ey-beneficios__card-desc">{b.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ey-beneficios {
    padding-block: clamp(48px, 8vh, 96px);
    background: var(--bg-dark-1);
    color: var(--text-on-dark);
    scroll-margin-top: 80px;
  }

  .ey-beneficios__container {
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 48px);
  }

  .ey-beneficios__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(32px, 5vh, 56px);
  }

  .ey-beneficios__eyebrow {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-on-dark);
    margin: 0 0 16px;
    text-align: center;
  }

  .ey-beneficios__title {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.2;
    font-weight: 300;
    margin: 0 0 16px;
    text-align: center;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .ey-beneficios__title em {
    font-style: italic;
    font-weight: 500;
    color: #E8D9B5;
  }

  .ey-beneficios__intro {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: clamp(0.95rem, 1.4vw, 1.0625rem);
    line-height: 1.65;
    margin: 0;
    text-align: center;
    color: var(--text-on-dark-muted);
  }

  .ey-beneficios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }

  .ey-beneficios__card {
    padding: clamp(20px, 2.5vw, 28px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-on-dark);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease, background 200ms ease;
    contain: layout style;
  }
  .ey-beneficios__card:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .ey-beneficios__num {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--accent-on-dark);
    margin: 0 0 8px;
  }

  .ey-beneficios__card-title {
    font-family: 'Cormorant Garamond', 'Cormorant Fallback', 'Georgia', serif;
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    font-weight: 500;
    margin: 0 0 8px;
    color: #FFFFFF;
    line-height: 1.25;
  }

  .ey-beneficios__card-desc {
    font-family: 'Outfit', 'Outfit Fallback', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    color: var(--text-on-dark-muted);
  }

  @media (max-width: 900px) {
    .ey-beneficios__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .ey-beneficios__grid { grid-template-columns: 1fr; }
  }
</style>
