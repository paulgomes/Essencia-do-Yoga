---
// Hero #studio - reconstrução fiel
---

<section id="studio" aria-labelledby="studioTitle" itemscope itemtype="https://schema.org/HealthClub">
  <div class="studio-hero__bg" aria-hidden="true">
    <video autoplay muted loop playsinline preload="metadata" disablepictureinpicture
           poster="/images/yoga-sunset-poster.webp">
      <source src="/videos/yoga-sunset.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="studio-hero__overlay" aria-hidden="true"></div>

  <div class="studio-hero__content">
    <div class="studio-hero__logo">
      <img src="/images/logo.png"
           alt="Essência do Yoga — studio de yoga em Sorocaba"
           decoding="async"
           fetchpriority="high"
           width="118"
           height="121">
    </div>

    <p class="studio-hero__tag">Studio de Yoga em Sorocaba</p>

    <h1 class="studio-hero__title" id="studioTitle" itemprop="name">
      Yoga em Sorocaba: um <em>cantinho</em> para você <em>respirar</em>.
    </h1>

    <p class="studio-hero__description" itemprop="description">
      Turmas enxutas, professora que sabe o seu nome e aulas pensadas
      para o seu momento — no coração de Sorocaba.
    </p>

    <a href="#contato" class="studio-hero__cta" aria-label="Ver modalidades de yoga oferecidas">Ver Modalidades</a>

    <div class="studio-hero__features" role="list">
      <div class="studio-hero__feature" role="listitem"><span aria-hidden="true">01</span>Turmas pequenas e acolhedoras</div>
      <div class="studio-hero__feature" role="listitem"><span aria-hidden="true">02</span>Horários flexíveis</div>
      <div class="studio-hero__feature" role="listitem"><span aria-hidden="true">03</span>Professora certificada</div>
    </div>
  </div>
</section>

<style>
  #studio {
    --yoga-green: #1D603E;
    --yoga-green-dark: #154A30;
    --yoga-lime: #BEEBAC;
    --yoga-white: #ffffff;

    position: relative;
    min-height: calc(100vh - 114px);
    min-height: calc(100dvh - 114px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #080e0a;
    color: #fff !important;
    padding: 42px clamp(1.5rem, 1rem + 3vw, 4rem) 56px;
  }

  #studio * { box-sizing: border-box; }

  #studio .studio-hero__bg { position: absolute; inset: 0; z-index: 1; }

  #studio .studio-hero__bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: brightness(.68) saturate(1.02);
  }

  #studio .studio-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(8,14,10,.42) 0%,
      rgba(8,14,10,.50) 48%,
      rgba(8,14,10,.72) 100%
    );
  }

  #studio .studio-hero__content {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: 920px;
    text-align: center;
    transform: translateY(-12px);
  }

  #studio .studio-hero__logo {
    display: flex;
    justify-content: center;
    margin-bottom: 22px;
  }

  #studio .studio-hero__logo img {
    max-width: 118px;
    width: auto;
    height: auto;
    filter: brightness(0) invert(1) drop-shadow(0 10px 24px rgba(0,0,0,.25));
  }

  #studio .studio-hero__tag {
    display: inline-flex;
    padding: 7px 20px;
    background: rgba(190,235,172,.15);
    border: 1px solid rgba(190,235,172,.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 24px;
    color: #BEEBAC !important;
  }

  #studio .studio-hero__title {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: clamp(36px, 5.2vw, 68px) !important;
    line-height: 1.06 !important;
    font-weight: 300 !important;
    margin: 0 auto 22px !important;
    letter-spacing: -1.5px !important;
    color: #ffffff !important;
    max-width: 980px;
    text-wrap: balance;
  }

  #studio .studio-hero__title em {
    font-style: italic !important;
    color: #BEEBAC !important;
  }

  #studio .studio-hero__description {
    font-size: clamp(15px, 1.25vw, 18px) !important;
    font-weight: 300 !important;
    color: rgba(255,255,255,.88) !important;
    max-width: 680px;
    margin: 0 auto 30px !important;
    line-height: 1.65 !important;
  }

  #studio .studio-hero__cta,
  #studio .studio-hero__cta:visited {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    background: #ffffff !important;
    color: #154A30 !important;
    padding: 15px 36px;
    border-radius: 999px;
    font-weight: 800 !important;
    font-size: 12px !important;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    text-decoration: none !important;
    transition: all .35s ease;
    box-shadow: 0 12px 28px rgba(0,0,0,.18);
  }

  #studio .studio-hero__cta:hover,
  #studio .studio-hero__cta:focus-visible {
    transform: translateY(-3px);
    background: #BEEBAC !important;
    color: #154A30 !important;
    outline: 2px solid #BEEBAC;
    outline-offset: 3px;
  }

  #studio .studio-hero__features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 820px;
    margin: 38px auto 0;
    border-top: 1px solid rgba(255,255,255,.18);
    padding-top: 28px;
    gap: 22px;
  }

  #studio .studio-hero__feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: rgba(255,255,255,.78) !important;
    letter-spacing: 1.1px;
    font-family: 'Outfit', sans-serif;
  }

  #studio .studio-hero__feature span {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 24px;
    font-style: italic;
    color: #BEEBAC !important;
    line-height: 1;
  }

  @media (max-width: 768px) {
    #studio {
      min-height: calc(100vh - 64px);
      min-height: calc(100dvh - 64px);
      padding: 44px clamp(1.25rem, 4vw, 1.75rem) 48px;
    }
    #studio .studio-hero__content { transform: none; }
    #studio .studio-hero__logo img { max-width: 88px; }
    #studio .studio-hero__bg video { object-position: 50% 30%; }
    #studio .studio-hero__tag {
      font-size: 9px;
      letter-spacing: 2px;
      padding: 6px 16px;
      margin-bottom: 18px;
    }
    #studio .studio-hero__title {
      font-size: clamp(30px, 8vw, 38px) !important;
      letter-spacing: -0.8px !important;
    }
    #studio .studio-hero__description {
      font-size: 14px !important;
      margin-bottom: 26px !important;
      line-height: 1.7 !important;
    }
    #studio .studio-hero__cta { width: 100%; max-width: 320px; }
    #studio .studio-hero__features {
      grid-template-columns: 1fr;
      margin-top: 32px;
      padding-top: 24px;
      gap: 16px;
    }
    #studio .studio-hero__feature {
      flex-direction: row;
      justify-content: center;
      gap: 12px;
    }
    #studio .studio-hero__feature span { font-size: 20px; min-width: 28px; text-align: right; }
  }

  @media (max-width: 380px) {
    #studio { padding: 32px 14px 40px; }
    #studio .studio-hero__title { font-size: 28px !important; }
    #studio .studio-hero__description { font-size: 13px !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    #studio .studio-hero__bg video { display: none; }
    #studio .studio-hero__cta { transition: none; }
  }
</style>
